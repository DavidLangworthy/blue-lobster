{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "azureOpenAiEndpoint": {
      "value": "${AZURE_OPENAI_ENDPOINT}"
    },
    "azureOpenAiApiKey": {
      "value": "${AZURE_OPENAI_API_KEY}"
    },
    "azureOpenAiDeployment": {
      "value": "${AZURE_OPENAI_DEPLOYMENT=gpt-5-2}"
    },
    "anthropicApiKey": {
      "value": "${ANTHROPIC_API_KEY}"
    },
    "openclawGatewayToken": {
      "value": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "openclawPersonaName": {
      "value": "${OPENCLAW_PERSONA_NAME=Clawd}"
    },
    "openclawModel": {
      "value": "${OPENCLAW_MODEL}"
    },
    "openclawModelFallbacks": {
      "value": "${OPENCLAW_MODEL_FALLBACKS=anthropic/claude-sonnet-4-6}"
    },
    "openclawRooms": {
      "value": "${OPENCLAW_ROOMS=living-room,master-bedroom}"
    },
    "whatsappAllowFrom": {
      "value": "${WHATSAPP_ALLOW_FROM}"
    },
    "outlookEmail": {
      "value": "${OUTLOOK_EMAIL}"
    },
    "outlookAppPassword": {
      "value": "${OUTLOOK_APP_PASSWORD}"
    },
    "imapHost": {
      "value": "${IMAP_HOST=outlook.office365.com}"
    },
    "imapPort": {
      "value": "${IMAP_PORT=993}"
    },
    "smtpHost": {
      "value": "${SMTP_HOST=smtp.office365.com}"
    },
    "smtpPort": {
      "value": "${SMTP_PORT=587}"
    },
    "azureSpeechKey": {
      "value": "${AZURE_SPEECH_KEY}"
    },
    "azureSpeechRegion": {
      "value": "${AZURE_SPEECH_REGION}"
    },
    "azureSpeechLanguage": {
      "value": "${AZURE_SPEECH_LANGUAGE=en-US}"
    },
    "allowedIpRanges": {
      "value": "${ALLOWED_IP_RANGES}"
    },
    "internalOnly": {
      "value": "${INTERNAL_ONLY=false}"
    },
    "enableAlerts": {
      "value": "${ENABLE_ALERTS=true}"
    },
    "alertEmailAddress": {
      "value": "${ALERT_EMAIL_ADDRESS}"
    }
  }
}
