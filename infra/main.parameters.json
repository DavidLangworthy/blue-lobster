{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "existingContainerRegistryName": {
      "value": "${EXISTING_CONTAINER_REGISTRY_NAME}"
    },
    "deployAzureOpenAi": {
      "value": "${DEPLOY_AZURE_OPENAI=true}"
    },
    "azureOpenAiAccountName": {
      "value": "${AZURE_OPENAI_ACCOUNT_NAME}"
    },
    "azureOpenAiSkuName": {
      "value": "${AZURE_OPENAI_SKU_NAME=S0}"
    },
    "azureOpenAiEndpoint": {
      "value": "${AZURE_OPENAI_ENDPOINT}"
    },
    "azureOpenAiApiKey": {
      "value": "${AZURE_OPENAI_API_KEY}"
    },
    "azureOpenAiDeployment": {
      "value": "${AZURE_OPENAI_DEPLOYMENT=gpt-5-2}"
    },
    "azureOpenAiReasoning": {
      "value": "${AZURE_OPENAI_REASONING=false}"
    },
    "deployAzureOpenAiModel": {
      "value": "${DEPLOY_AZURE_OPENAI_MODEL=true}"
    },
    "azureOpenAiModelName": {
      "value": "${AZURE_OPENAI_MODEL_NAME=gpt-4.1}"
    },
    "azureOpenAiModelVersion": {
      "value": "${AZURE_OPENAI_MODEL_VERSION=2025-04-14}"
    },
    "azureOpenAiDeploymentSkuName": {
      "value": "${AZURE_OPENAI_DEPLOYMENT_SKU_NAME=Standard}"
    },
    "azureOpenAiDeploymentSkuCapacity": {
      "value": "${AZURE_OPENAI_DEPLOYMENT_SKU_CAPACITY=1}"
    },
    "anthropicApiKey": {
      "value": "${ANTHROPIC_API_KEY}"
    },
    "openclawGatewayToken": {
      "value": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "openclawPersonaName": {
      "value": "${OPENCLAW_PERSONA_NAME=Clawd}"
    },
    "openclawModel": {
      "value": "${OPENCLAW_MODEL}"
    },
    "openclawModelFallbacks": {
      "value": "${OPENCLAW_MODEL_FALLBACKS}"
    },
    "openclawRooms": {
      "value": "${OPENCLAW_ROOMS=living-room,master-bedroom}"
    },
    "openclawTtsProvider": {
      "value": "${OPENCLAW_TTS_PROVIDER=edge}"
    },
    "openclawTtsAuto": {
      "value": "${OPENCLAW_TTS_AUTO=inbound}"
    },
    "openclawControlUiDisableDeviceAuth": {
      "value": "${OPENCLAW_CONTROLUI_DISABLE_DEVICE_AUTH=true}"
    },
    "whatsappAllowFrom": {
      "value": "${WHATSAPP_ALLOW_FROM}"
    },
    "whatsappDmPolicy": {
      "value": "${WHATSAPP_DM_POLICY}"
    },
    "whatsappGroupPolicy": {
      "value": "${WHATSAPP_GROUP_POLICY}"
    },
    "outlookEmail": {
      "value": "${OUTLOOK_EMAIL}"
    },
    "outlookAppPassword": {
      "value": "${OUTLOOK_APP_PASSWORD}"
    },
    "imapHost": {
      "value": "${IMAP_HOST=outlook.office365.com}"
    },
    "imapPort": {
      "value": "${IMAP_PORT=993}"
    },
    "smtpHost": {
      "value": "${SMTP_HOST=smtp.office365.com}"
    },
    "smtpPort": {
      "value": "${SMTP_PORT=587}"
    },
    "azureSpeechKey": {
      "value": "${AZURE_SPEECH_KEY}"
    },
    "azureSpeechRegion": {
      "value": "${AZURE_SPEECH_REGION}"
    },
    "azureSpeechLanguage": {
      "value": "${AZURE_SPEECH_LANGUAGE=en-US}"
    },
    "elevenLabsApiKey": {
      "value": "${ELEVENLABS_API_KEY}"
    },
    "imageTag": {
      "value": "${IMAGE_TAG=latest}"
    },
    "useOfficialImage": {
      "value": "${USE_OFFICIAL_IMAGE=false}"
    },
    "scalePollingIntervalSeconds": {
      "value": "${SCALE_POLLING_INTERVAL_SECONDS=30}"
    },
    "scaleCooldownSeconds": {
      "value": "${SCALE_COOLDOWN_SECONDS=3600}"
    },
    "heartbeatCronStart": {
      "value": "${HEARTBEAT_CRON_START=0 8-20 * * *}"
    },
    "heartbeatCronEnd": {
      "value": "${HEARTBEAT_CRON_END=5 8-20 * * *}"
    },
    "heartbeatCronTimezone": {
      "value": "${HEARTBEAT_CRON_TIMEZONE=America/Los_Angeles}"
    },
    "allowedIpRanges": {
      "value": "${ALLOWED_IP_RANGES}"
    },
    "internalOnly": {
      "value": "${INTERNAL_ONLY=false}"
    },
    "enableAlerts": {
      "value": "${ENABLE_ALERTS=false}"
    },
    "alertEmailAddress": {
      "value": "${ALERT_EMAIL_ADDRESS}"
    }
  }
}
